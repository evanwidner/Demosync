# Anthropic Claude API (organizational pass, camera path, QA, voiceover script)
ANTHROPIC_API_KEY=

# Supabase — used by the dashboard for browser-side data when needed (Realtime, RLS).
# These are safe to commit/expose — the publishable key is designed for public client use.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Postgres direct connection — used by server-side dashboard code, the daemon, and the
# worker job_handler. Grab this from Supabase: Project Settings → Database → Connection
# string (URI / "Session" mode, not "Transaction" — we need LISTEN/NOTIFY).
# Format: postgresql://postgres:<YOUR-DB-PASSWORD>@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
DATABASE_URL=

# RunPod (GPU worker orchestration) — only needed for prod dispatch, not local runs
RUNPOD_API_KEY=
RUNPOD_TEMPLATE_ID=
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 4090

# ElevenLabs (optional voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# AWS S3 (output mirror, optional) — leave blank to use local dashboard/uploads/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
S3_BUCKET=

# Supabase server-side (used by daemon and worker for Storage uploads and direct DB access)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Storage root for the dashboard file server (defaults to dashboard/uploads/)
STORAGE_ROOT=
